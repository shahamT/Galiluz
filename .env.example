# ── Database ──────────────────────────────────────────────────────────────
# IMPORTANT: dev and prod must use different MONGODB_DB_NAME values.
# Never switch by commenting/uncommenting lines — set per environment
# (locally: valley_luz_app_dev; on Render: valley_luz_app via dashboard env).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net
MONGODB_DB_NAME=valley_luz_app_dev
MONGODB_COLLECTION_EVENTS=events
# When set, wa-bot create API writes here instead of the main events collection (testing)
MONGODB_COLLECTION_EVENTS_WA_BOT=events
MONGODB_COLLECTION_RAW_MESSAGES=raw_messages
MONGODB_COLLECTION_PUBLISHERS=publishers
MONGODB_COLLECTION_EVENT_LOGS=eventLogs
MONGODB_COLLECTION_AUTH_LOGS=authLogs
MONGODB_COLLECTION_EVENT_INTERACTIONS=eventInteractions
MONGODB_COLLECTION_EVENT_STATS=eventStats
MONGODB_COLLECTION_EVENT_OCCURRENCE_STATS=eventOccurrenceStats
# Optional (defaults shown): global app settings, crawler dedup (TTL 21d), magic-link tokens (TTL).
MONGODB_COLLECTION_APP_SETTINGS=appSettings
MONGODB_COLLECTION_CRAWLER_MESSAGES=crawlerMessages
MONGODB_COLLECTION_MAGIC_LINKS=magicLinks
# Enrolled WebAuthn passkeys (staff second factor).
MONGODB_COLLECTION_WEBAUTHN_CREDENTIALS=webauthnCredentials

# ── WebAuthn passkeys (staff second factor) ───────────────────────────────
# Relying-Party identity. Leave UNSET to auto-derive: dev → localhost:3000,
# prod → from NUXT_PUBLIC_SITE_URL. Override only for a non-primary preview domain.
# WEBAUTHN_RP_ID=galiluz.co.il
# WEBAUTHN_ORIGIN=https://galiluz.co.il

# ── Secrets (production startup fails if missing) ─────────────────────────
# Shared secret between the web server and the WhatsApp apps (X-API-Key)
API_SECRET=change-me-min-16-chars
# HMAC secret for OTP hashing + session tokens (min 32 chars)
OTP_SECRET=change-me-min-32-chars-random-string

# ── WhatsApp Gateway (OTP delivery via Green API bridge) ──────────────────
# The Nuxt app POSTs OTP sends to the wa-gateway service (apps/wa-gateway),
# authenticated with API_SECRET. Locally, run `npm run dev:wa-gateway` and point
# this at it; if unset in dev, the OTP is printed to the Nuxt terminal instead.
WA_GATEWAY_URL=http://localhost:3030
# URL of the wa-bot service — web registration calls it (/internal/notify-approver,
# API_SECRET) to send the approver the Approve/Reject buttons. Unset in dev → the
# approver notification is skipped (logged); registration still completes.
WA_BOT_URL=http://localhost:3001
# Approvers are managed in the admin portal (ניהול מאשרים) — no env var. See
# docs/flows/approver-management.md.

# ── WhatsApp Cloud API (legacy — wa-bot only; OTP no longer uses this) ─────
WA_CLOUD_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=

# ── Cloudinary (event media) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=wa-bot-events

# ── OpenAI (event extraction) ─────────────────────────────────────────────
# Required by BOTH the wa-bot and the web app's AI event-generation endpoint.
OPENAI_API_KEY=
# Model for the wa-bot extraction pipeline.
OPENAI_MODEL=gpt-4o-mini
# Model for the web app's AI event generation — REQUIRED (no hardcoded default;
# the /api/publisher/event/ai-generate endpoint returns 503 if unset). Use a
# stronger model here than the wa-bot for better category/description inference.
OPENAI_MODEL_WEB=gpt-4o

# ── Analytics (public) ────────────────────────────────────────────────────
NUXT_PUBLIC_POSTHOG_PUBLIC_KEY=
NUXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NUXT_PUBLIC_POSTHOG_DEFAULTS=2026-01-30
NUXT_PUBLIC_POSTHOG_IN_DEV=false

# ── Notification emails (optional — mailer no-ops when unset) ─────────────
# Zoho SMTP: org accounts with a custom domain use smtppro.zoho.com (.eu for EU DC).
# SMTP_PASS is a Zoho app-specific password (Zoho Accounts → Security → App Passwords).
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=465
SMTP_USER=shaham@galiluz.co.il
SMTP_PASS=
MAIL_FROM=noreply@galiluz.co.il
MAIL_TO=shaham@galiluz.co.il

# ── Cloudflare Turnstile (optional — login captcha; set both or neither) ──
# Widget at dash.cloudflare.com → Turnstile; hostnames: galiluz.co.il + localhost
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Ops (optional) ────────────────────────────────────────────────────────
# Persist rate-limit counters across restarts (single-instance file store)
RATE_LIMIT_FILE_PATH=
# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
