# wa-bot – WhatsApp Cloud API
# Copy to .env and fill values. Do not commit .env.

PORT=3001
WEBHOOK_VERIFY_TOKEN=your_verify_token
WA_CLOUD_ACCESS_TOKEN=your_wa_cloud_access_token
WA_PHONE_NUMBER_ID=your_phone_number_id
PUBLISHERS_APPROVER_WA_NUMBER=972501234567

# Optional: Galiluz app (events API)
# GALILUZ_APP_URL=https://galiluz.co.il
# GALILUZ_APP_API_KEY=
# API_SECRET=

# Optional: OpenAI (event create flow)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional: Log level (info, warn, error, debug)
# LOG_LEVEL=info

# --- Dev forward (production server only) ---
# Meta webhook stays configured to PRODUCTION URL only. When you develop locally:
# - On Render (production): set WHATSAPP_DEV_FORWARD_ENABLED=true and WHATSAPP_DEV_FORWARD_URL
#   to your current ngrok URL. Restart the production server after changing env.
# - Payloads for the test number are then forwarded to ngrok; prod number is handled on prod.
# - When not developing, set WHATSAPP_DEV_FORWARD_ENABLED=false (or leave unset).

# Test number's phone_number_id (Meta test number, e.g. +1 555 169 9470)
# WHATSAPP_TEST_PHONE_NUMBER_ID=1028248877037153

# Optional: prod number id; if blank, any non-test payload is treated as prod
# WHATSAPP_PROD_PHONE_NUMBER_ID=

# Set true on production (Render) when you want test payloads forwarded to your ngrok
# WHATSAPP_DEV_FORWARD_ENABLED=false

# Ngrok base URL, no trailing slash (only used when WHATSAPP_DEV_FORWARD_ENABLED=true)
# WHATSAPP_DEV_FORWARD_URL=https://xxxx-xxxx.ngrok-free.app

# Path to append for forward POST (default /webhook)
# WHATSAPP_DEV_FORWARD_PATH=/webhook
