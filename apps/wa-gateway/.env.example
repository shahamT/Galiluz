# WhatsApp Gateway (Green API bridge)
# Copy to apps/wa-gateway/.env for local development.

# Port the gateway HTTP server listens on (Render injects PORT in prod).
PORT=3030

# Must match the web app's API_SECRET — gates the /internal/* routes.
API_SECRET=change-me-min-16-chars

# Web app base URL — the crawler forwards group messages to its internal API.
# Local dev: http://localhost:3000 ; production: https://galiluz.co.il
WEB_APP_URL=http://localhost:3000

# Optional: token Green API sends on incoming webhooks (Authorization: Bearer).
# Set the SAME value as the instance's webhookUrlToken; verified only when set.
GREEN_API_WEBHOOK_TOKEN=

# Green API instance credentials (Green API console → your instance).
GREEN_API_ID_INSTANCE=
GREEN_API_API_TOKEN_INSTANCE=

# Optional host overrides. Defaults: https://api.green-api.com / https://media.green-api.com
# Some instances use a dedicated host, e.g. https://7105.api.green-api.com
GREEN_API_BASE_URL=
GREEN_API_MEDIA_URL=

# Optional: error | warn | info | debug (default info)
WA_LOG_LEVEL=info
